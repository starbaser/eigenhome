# NixOS-level module: runs hjem-compat activation scripts after hjem links files.
#
# Creates a hjem-compat-activate@<user>.service template that:
#   1. Runs after hjem-activate@<user>.service (files are linked)
#   2. Triggers systemctl --user daemon-reload (picks up new/changed units)
#   3. Executes the activation script if it exists
#
# Dependency chain:
#   hjem.target → hjem-activate@alice → hjem-compat-activate@alice
{
  config,
  lib,
  ...
}: let
  inherit
    (lib)
    attrNames
    filterAttrs
    mkIf
    ;

  cfg = config.hjem;
  enabledUsers = filterAttrs (_: u: u.enable) cfg.users;
  hasUsers = enabledUsers != {};
  hasLinker = cfg.linker != null;
in {
  config = mkIf (hasUsers && hasLinker) {
    systemd.services."hjem-compat-activate@" = {
      description = "Run hjem-compat activation scripts for %i";
      serviceConfig = {
        User = "%i";
        Type = "oneshot";
      };
      after = ["hjem-activate@%i.service"];
      requires = ["hjem-activate@%i.service"];
      script = ''
        export XDG_RUNTIME_DIR="/run/user/$(id -u)"

        # Reload systemd user daemon to pick up new/changed unit files.
        systemctl --user daemon-reload || true

        # Run activation script if generated by hjem-compat.
        activate="$HOME/.local/share/hjem-compat/activate"
        if [ -x "$activate" ]; then
          "$activate"
        fi
      '';
    };

    # Extend hjem.target to include our activation service for each user.
    systemd.targets.hjem.requires =
      map (user: "hjem-compat-activate@${user}.service") (attrNames enabledUsers);
  };
}
