# NixOS-level module: runs eigenhome activation scripts after files are linked.
#
# Creates an eigenhome-user-activation@<user>.service template that:
#   1. Runs after eigenhome-activate@<user>.service (files are linked)
#   2. Runs before eigenhome-copy@<user>.service (manifest is committed)
#   3. Triggers systemctl --user daemon-reload (picks up new/changed units)
#   4. Executes the activation script if it exists
#
# Dependency chain:
#   eigenhome.target → eigenhome-activate@alice → eigenhome-user-activation@alice → eigenhome-copy@alice
{
  config,
  lib,
  ...
}: let
  inherit
    (lib)
    attrNames
    filterAttrs
    mkIf
    ;

  cfg = config.eigenhome;
  enabledUsers = filterAttrs (_: u: u.enable) cfg.users;
  hasUsers = enabledUsers != {};
  hasLinker = cfg.linker != null;
in {
  config = mkIf (hasUsers && hasLinker) {
    systemd.services."eigenhome-user-activation@" = {
      description = "Run user activation scripts for %i";
      serviceConfig = {
        User = "%i";
        Type = "oneshot";
      };
      after = ["eigenhome-activate@%i.service"];
      requires = ["eigenhome-activate@%i.service"];
      before = ["eigenhome-copy@%i.service"];
      script = ''
        export XDG_RUNTIME_DIR="/run/user/$(id -u)"

        # Reload systemd user daemon to pick up new/changed unit files.
        systemctl --user daemon-reload || true

        # Run activation script if generated by eigenhome.
        activate="$HOME/.local/share/eigenhome/activate"
        if [ -x "$activate" ]; then
          "$activate"
        fi
      '';
    };

    # Extend eigenhome.target to include our activation service for each user.
    systemd.targets.eigenhome.requires =
      map (user: "eigenhome-user-activation@${user}.service") (attrNames enabledUsers);
  };
}
